<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">
<module name="Checker">
  <!-- Read source files as UTF-8 to match project encoding. -->
  <property name="charset" value="UTF-8"/>
  <!-- Treat all violations as errors so CI fails on style issues. -->
  <property name="severity" value="error"/>

  <!-- TreeWalker runs Java AST-based code style checks. -->
  <module name="TreeWalker">
    <!-- Disallow wildcard imports to keep dependencies explicit. -->
    <module name="AvoidStarImport"/>
    <!-- Fail when imports are declared but never used. -->
    <module name="UnusedImports"/>
    <!-- Require braces for control statements (if/for/while/etc.). -->
    <module name="NeedBraces"/>
    <!-- Prevent empty code blocks that can hide missing logic. -->
    <module name="EmptyBlock"/>
    <!-- Enforce a maximum of 1 consecutive empty line to avoid excessive whitespace. -->
    <module name="EmptyLineSeparator">
      <property name="allowNoEmptyLineBetweenFields" value="true"/>
      <property name="allowMultipleEmptyLines" value="false"/>
    </module>
    <!-- Enforce curly braces at the same line for all control statements. -->
    <module name="LeftCurly">
      <property name="option" value="eol"/>
    </module>
  </module>
  <!-- Enforce a maximum line length of 120 characters for readability. -->
  <module name="LineLength">
    <property name="max" value="120"/>
  </module>
</module>